APP_NAME=oMsg API
ENVIRONMENT=development
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=90
DATABASE_URL=sqlite:///./omsg.db
DATABASE_AUTO_MIGRATE=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RELEASE_MANIFEST_PATH=./releases/manifest.json
LOGIN_CODE_EXPIRE_SECONDS=300
LOGIN_CODE_MAX_ATTEMPTS=5
LOGIN_CODE_LENGTH=5
# AUTH_TEST_CODE=12345

# SMS providers: disabled | test | twilio
SMS_PROVIDER=disabled
SMS_CODE_TEMPLATE={app_name}: {code}
# Generic Android SMS gateway (send from your SIM phone)
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_AUTH_HEADER=Authorization
SMS_GATEWAY_AUTH_PREFIX=Bearer
SMS_GATEWAY_TO_FIELD=to
SMS_GATEWAY_MESSAGE_FIELD=message
SMS_GATEWAY_TIMEOUT_SECONDS=12
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=
